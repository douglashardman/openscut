# /etc/scut/register.env
#
# Environment for scut-register.service. Installed by
# ops/scripts/install.sh as a template; the wallet key MUST be filled
# in by hand after install. Owned by root:scut, mode 0640.

SCUT_REGISTER_HOST=127.0.0.1
SCUT_REGISTER_PORT=8445

SCUT_REGISTER_CHAIN_ID=8453
SCUT_REGISTER_CONTRACT_ADDRESS=0x199b48E27a28881502b251B0068F388Ce750feff

# Public Base RPC works for low-volume use, but is load-balanced and
# can serve stale state for 1-2 blocks after a write. The register
# service polls past this, but for higher throughput point this at a
# dedicated endpoint (Alchemy, QuickNode, or a self-hosted Base node).
SCUT_REGISTER_RPC_URL=https://mainnet.base.org

# Number of confirmations to wait on each tx before treating it as
# final. 1 is fine for most uses; bump to 2 if RPC consistency is
# flaky.
SCUT_REGISTER_CONFIRMATIONS=1

# REQUIRED. 0x-prefixed 64-char hex private key for the service
# wallet that pays gas and custodies registered tokens. Set this by
# hand after install... never commit to git, never log.
SCUT_REGISTER_WALLET_KEY=0x__FILL_THIS_IN_BY_HAND__

SCUT_REGISTER_DB_PATH=/var/lib/scut/register.db

# Default relay used when a registration request omits relays[].
SCUT_REGISTER_DEFAULT_RELAY=relay.openscut.ai

# Per-IP and global daily caps. Anti-abuse: the service wallet is the
# attack surface, so these limits cap the gas a single IP can drain
# and the total daily budget.
SCUT_REGISTER_RATE_LIMIT_PER_IP=10
SCUT_REGISTER_RATE_LIMIT_GLOBAL=1000
