# /etc/scut/resolver.env
#
# Environment for scut-resolver.service. Installed by
# ops/scripts/install.sh. Owned by root:scut, mode 0640.

SCUT_RESOLVER_HOST=127.0.0.1
SCUT_RESOLVER_PORT=8444

# Prod reads from any SII-compliant contract on Base mainnet.
# The contract address here is the default used when a client passes
# a bare token id (no scut:// URI). Any contract on chain 8453
# resolves correctly when the client sends the full URI.
SCUT_RESOLVER_REGISTRY_BACKEND=sii
SCUT_RESOLVER_CONTRACT_ADDRESS=0x199b48E27a28881502b251B0068F388Ce750feff
SCUT_RESOLVER_CHAIN_ID=8453
SCUT_RESOLVER_BASE_RPC_URL=https://mainnet.base.org

SCUT_RESOLVER_CACHE_TTL_SECONDS=300
SCUT_RESOLVER_IPFS_GATEWAY=https://ipfs.io/ipfs/
