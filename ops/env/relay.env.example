# /etc/scut/relay.env
#
# Environment for scut-relay.service. Installed by
# ops/scripts/install.sh. Owned by root:scut, mode 0640.
# The events token is generated by the install script on first run;
# check `sudo cat /etc/scut/relay.env | grep EVENTS_TOKEN` after install.

SCUT_RELAY_HOST=127.0.0.1
SCUT_RELAY_PORT=8443
SCUT_RELAY_DB=/var/lib/scut/relay.db

# Relay resolves sender signing keys via the local resolver.
# Loopback — no TLS overhead for in-host traffic.
SCUT_RELAY_RESOLVER_URL=http://127.0.0.1:8444

# Generated at install time: openssl rand -hex 32
SCUT_RELAY_EVENTS_TOKEN=CHANGEME_GENERATE_VIA_INSTALL_SCRIPT

SCUT_RELAY_MAX_ENVELOPE_BYTES=102400
SCUT_RELAY_MAX_TTL_SECONDS=604800
SCUT_RELAY_RATE_PER_SENDER_PER_MINUTE=60
SCUT_RELAY_RATE_GLOBAL_PER_MINUTE=60000
