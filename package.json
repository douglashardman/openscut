{
  "name": "openscut",
  "version": "0.1.0",
  "private": true,
  "description": "OpenSCUT reference implementation monorepo",
  "license": "MIT",
  "author": "Doug Hardman <doug@mrdoug.com>",
  "homepage": "https://openscut.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/douglashardman/openscut.git"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "test": "pnpm -r --filter './packages/*' run test",
    "lint": "pnpm -r --filter './packages/*' run lint",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck",
    "clean": "pnpm -r --filter './packages/*' exec rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
