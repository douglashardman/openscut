{
  "name": "scut-resolver",
  "version": "0.1.0",
  "description": "SCUT identity document resolver. Fetches and caches ERC-8004 identity documents.",
  "license": "MIT",
  "author": "Doug Hardman <doug@mrdoug.com>",
  "homepage": "https://openscut.ai",
  "repository": {
    "type": "git",
