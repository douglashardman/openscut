{
  "name": "scut-monitor",
  "version": "0.1.0",
  "description": "SCUT terminal monitor. Live envelope stream with reveal animation.",
  "license": "MIT",
  "author": "Doug Hardman <doug@mrdoug.com>",
  "homepage": "https://openscut.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/douglashardman/openscut.git",
    "directory": "packages/monitor"
  },
  "type": "module",
  "bin": {
    "scut-monitor": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src test --no-error-on-unmatched-pattern",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "spike": "tsx spike/reveal-spike.tsx"
  },
  "dependencies": {
    "@openscut/core": "workspace:*",
    "ink": "^7.0.1",
    "react": "^19.2.5"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
